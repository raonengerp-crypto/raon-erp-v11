const API='/api';
const state={token:localStorage.getItem('token')||'',user:JSON.parse(localStorage.getItem('user')||'null'),page:'dashboard',data:{},tab:{tax:'sales',quote:'single'},editing:null};
const menus=[['dashboard','대시보드'],['sites','현장관리'],['quotes','견적관리'],['contracts','계약관리'],['products','상품DB'],['extras','추가비DB'],['materials','자재관리'],['tax','세무관리'],['as','AS관리'],['customers','업체/고객관리'],['employees','직원관리'],['approvals','내부결제'],['network','업체네트워크'],['settings','설정'],['security','보안센터']];
const mobileMenus=[['mhome','홈'],['mschedule','일정'],['msites','현장'],['mas','AS'],['mprofile','내정보']];
const dateFields=['rough_start','rough_end','install_start','install_end','visit_date','contract_date','delivery_date','deposit_date','middle_date','balance_date','aftercare_due','paid_date','request_date','due_date','complete_date','install_complete_date'];
const money=n=>(Number(n)||0).toLocaleString('ko-KR')+'원';
const num=v=>Number(String(v||'').replace(/[^0-9.-]/g,''))||0;
const gid=id=>document.getElementById(id);
const esc=s=>String(s??'').replace(/[&<>"]/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[m]));
async function api(path,opt={}){const r=await fetch(API+path,{...opt,headers:{'Content-Type':'application/json',Authorization:'Bearer '+state.token,...(opt.headers||{})}});const j=await r.json().catch(()=>({}));if(!r.ok){if(r.status===401)logout();throw new Error(j.error||'요청 실패')}return j}
function mount(){document.getElementById('app').innerHTML=state.token?layout():loginView(); if(state.token) loadPage();}
function loginView(){return `<div class="login"><div class="login-card"><div class="brand"><h1>RAON ERP</h1><p>시스템에어컨 종합 관리시스템</p></div><div class="field"><label>아이디</label><input id="loginId" value="admin"></div><div class="field"><label>비밀번호</label><input id="loginPw" type="password" value="1234"></div><button class="btn primary" style="width:100%;margin-top:10px" onclick="login()">로그인</button><div style="display:flex;justify-content:space-between;margin-top:16px"><button class="btn" onclick="showSignup()">회원가입</button><button class="btn" onclick="alert('관리자에게 비밀번호 초기화를 요청하세요.')">아이디/비밀번호 찾기</button></div><p class="small" style="text-align:center;margin-top:20px">v1.1 LOCK · © RAON ERP</p></div></div>`}
function showSignup(){document.getElementById('app').innerHTML=`<div class="login"><div class="login-card"><div class="brand"><h1>회원가입</h1><p>개인 또는 업체 등록</p></div><div class="field"><label>가입구분</label><select id="suType"><option value="individual">개인 등록</option><option value="company">업체정보 등록</option></select></div><div class="field"><label>이름/담당자</label><input id="suName"></div><div class="field"><label>업체명</label><input id="suCompany"></div><div class="field"><label>사업자번호</label><input id="suBiz"></div><div class="field"><label>연락처</label><input id="suPhone"></div><div class="field"><label>아이디</label><input id="suId"></div><div class="field"><label>비밀번호</label><input id="suPw" type="password"></div><button class="btn primary" style="width:100%" onclick="signup()">가입요청</button><button class="btn" style="width:100%;margin-top:8px" onclick="mount()">뒤로</button></div></div>`}
async function signup(){const body={username:gid('suId').value,password:gid('suPw').value,name:gid('suName').value,company_name:gid('suCompany').value,company_type:gid('suType').value,biz_no:gid('suBiz').value,phone:gid('suPhone').value};await fetch(API+'/signup',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});alert('가입요청 완료. 관리자 승인 후 사용 가능합니다.');mount();}
async function login(){const res=await fetch(API+'/login',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({username:gid('loginId').value,password:gid('loginPw').value})});const j=await res.json();if(!res.ok)return alert(j.error||'로그인 실패');state.token=j.token;state.user=j.user;localStorage.setItem('token',j.token);localStorage.setItem('user',JSON.stringify(j.user));mount();}
function logout(){localStorage.clear();state.token='';state.user=null;mount();}
function layout(){return `<div class="topbar"><div class="logo">RAON ERP</div><div class="nav">${menus.map(m=>`<button class="${state.page===m[0]?'active':''}" onclick="go('${m[0]}')">${m[1]}</button>`).join('')}</div><div class="top-actions"><span>${esc(state.user?.name||'')}</span><button class="btn" onclick="logout()">로그아웃</button></div></div><main class="wrap" id="view"></main><div class="bottom-nav">${mobileMenus.map(m=>`<button class="${state.page===m[0]?'active':''}" onclick="go('${m[0]}')">${m[1]}</button>`).join('')}</div><div id="modal" class="modal"></div>`}
function go(p){state.page=p;loadPage();}
async function preload(){const keys=['sites','products','materials','extra_fees','customers']; await Promise.all(keys.map(k=>api('/'+k).then(v=>state.data[k]=v).catch(()=>state.data[k]=[])));}
async function loadPage(){const v=gid('view'); if(!v)return; v.innerHTML='<div class="card">불러오는 중...</div>'; try{await preload(); v.innerHTML=await (pages[state.page]||pages.dashboard)();}catch(e){v.innerHTML='<div class="card">오류: '+esc(e.message)+'</div>'}}
function title(t){return `<h1 class="title">${t}</h1>`}
function card(label,value,cls=''){return `<div class="card metric"><div class="label">${label}</div><div class="value ${cls}">${value}</div></div>`}
function table(rows,cols,tableName=''){return `<div class="table-wrap"><table class="table"><thead><tr>${cols.map(c=>`<th>${c[1]}</th>`).join('')}${tableName?'<th>관리</th>':''}</tr></thead><tbody>${rows.map(r=>`<tr>${cols.map(c=>`<td>${formatCell(r[c[0]],c[2])}</td>`).join('')}${tableName?`<td><button class="btn" onclick='editRow("${tableName}",${JSON.stringify(r).replace(/'/g,"&#39;")})'>수정</button><button class="btn danger" onclick="delRow('${tableName}','${r.id}')">삭제</button></td>`:''}</tr>`).join('')}</tbody></table></div>`}
function formatCell(v,type){if(type==='money')return money(v); if(type==='status')return `<span class="pill">${esc(v||'')}</span>`; return esc(v??'')}
function opts(arr,sel=''){return arr.map(x=>`<option ${String(sel)===String(x)?'selected':''}>${esc(x)}</option>`).join('')}
function siteOptions(sel=''){const rows=state.data.sites||[];return `<option value="">현장 선택</option>${rows.map(r=>`<option value="${esc(r.site_name)}" ${sel===r.site_name?'selected':''}>${esc(r.site_name)}</option>`).join('')}`}
function productOptions(sel=''){return `<option value="">모델 선택</option>${(state.data.products||[]).map(p=>`<option value="${p.id}" ${sel===p.id?'selected':''}>${esc(p.model)} · ${esc(p.line_up||p.category)} · ${money(p.price)}</option>`).join('')}`}
function field(f,row={}){const [key,label,kind,extra]=f; const val=row[key]??''; if(kind==='date'||dateFields.includes(key))return `<div class="field"><label>${label}</label><input id="${key}" type="date" value="${esc(val)}"></div>`; if(kind==='number')return `<div class="field"><label>${label}</label><input id="${key}" type="number" value="${esc(val)}"></div>`; if(kind==='select')return `<div class="field"><label>${label}</label><select id="${key}">${opts(extra||[],val)}</select></div>`; if(kind==='site')return `<div class="field"><label>${label}</label><select id="${key}">${siteOptions(val)}</select></div>`; if(kind==='product')return `<div class="field"><label>${label}</label><select id="${key}">${productOptions(val)}</select></div>`; if(kind==='textarea')return `<div class="field"><label>${label}</label><textarea id="${key}">${esc(val)}</textarea></div>`; return `<div class="field"><label>${label}</label><input id="${key}" value="${esc(val)}"></div>`}
function form(titleText,fields,tableName,row=null){const id='form_'+tableName;return `<div class="card" id="${id}"><h3>${titleText}</h3><div class="form-grid">${fields.map(f=>field(f,row||{})).join('')}</div><button class="btn primary" onclick='saveForm("${tableName}",${JSON.stringify(fields.map(f=>f[0]))},${row?`"${row.id}"`:'null'})'>${row?'수정 저장':'저장'}</button>${row?`<button class="btn" onclick="loadPage()">취소</button>`:''}</div>`}
async function saveForm(tableName,keys,id=null){const body={};keys.forEach(k=>body[k]=gid(k)?.value||''); if(id) await api('/'+tableName+'/'+id,{method:'PUT',body:JSON.stringify(body)}); else await api('/'+tableName,{method:'POST',body:JSON.stringify(body)}); alert('저장 완료'); state.editing=null; loadPage();}
function editRow(tableName,row){state.editing={table:tableName,row};loadPage();setTimeout(()=>document.getElementById('form_'+tableName)?.scrollIntoView({behavior:'smooth'}),50)}
async function delRow(tableName,id){if(!confirm('삭제할까요?'))return; await api('/'+tableName+'/'+id,{method:'DELETE'}); loadPage();}
function modal(html){gid('modal').className='modal show';gid('modal').innerHTML=`<div class="modal-box">${html}<br><button class="btn" onclick="closeModal()">닫기</button></div>`}
function closeModal(){gid('modal').className='modal';gid('modal').innerHTML=''}

const siteFields=[['site_name','현장명'],['customer_name','고객명'],['phone','연락처'],['address','주소'],['status','진행상태','select',['견적중','진행중','완료','보류']],['contract_amount','총공사금','number'],['machine_cost','기계대','number'],['material_cost','자재비','number'],['labor_cost','인건비','number'],['equipment_cost','장비비','number'],['etc_cost','기타비','number'],['install_cost','설치비','number'],['contract_date','계약일','date'],['rough_start','선배관 시작','date'],['rough_end','선배관 종료','date'],['install_start','기계설치 시작','date'],['install_end','기계설치 종료','date']];
const taxFields=[['site_name','현장명','site'],['direction','구분','select',['매출','매입']],['category','항목','select',['총공사금','계약금','중도금','잔금','기계대','자재비','인건비','장비비','기타비','AS매출','AS매입']],['amount','금액','number'],['paid_amount','실결제/입금','number'],['pay_status','상태','select',['결제완료','부분결제','미결제','입금완료','미수']],['proof_type','증빙','select',['세금계산서','카드','현금영수증','현금','계좌이체','무증빙']],['paid_date','일자','date'],['memo','메모','textarea']];
const pages={
 dashboard:async()=>{const d=await api('/dashboard');const sites=state.data.sites||[];return title('대시보드')+`<div class="grid cards">${card('총공사금',money(d.totalContract),'blue')}${card('총매출',money(d.sales),'green')}${card('총매입',money(d.purchase),'red')}${card('수익금',money(d.profit),d.profit>=0?'green':'red')}${card('미수금',money(d.receivable),'red')}${card('미지급금',money(d.payable),'orange')}</div><div class="grid two"><div class="card"><h3>월간 일정 캘린더</h3><div class="calendar">${Array.from({length:35},(_,i)=>{const day=i+1;const ev=sites.filter(s=>String(s.rough_start||'').endsWith('-'+String(day).padStart(2,'0'))||String(s.install_start||'').endsWith('-'+String(day).padStart(2,'0'))).slice(0,2);return `<div class="day" onclick="schedulePopup(${day})"><b>${day}</b>${ev.map(e=>`<div class="event">${esc(e.site_name)}</div>`).join('')}</div>`}).join('')}</div></div><div class="card"><h3>알림</h3><div class="kpi-row"><div class="kpi">승인대기<b>${d.approvalPending}</b></div><div class="kpi">미완료 AS<b>${d.asOpen}</b></div><div class="kpi">사후관리<b>${d.aftercareDue}</b></div></div><p class="small">카드 클릭/메뉴 이동으로 상세 확인</p></div></div>`},
 sites:async()=>{const rows=state.data.sites||[];const edit=state.editing?.table==='sites'?state.editing.row:null;return title('현장관리')+`<div class="card"><h3>현장명 선택 하향드롭</h3><div class="form-grid"><div class="field"><label>현장 선택</label><select onchange="showSite(this.value)"><option value="">현장 선택</option>${rows.map(r=>`<option value="${r.id}">${esc(r.site_name)}</option>`).join('')}</select></div><div class="field"><label>선택 현장 정보</label><input id="siteInfo" readonly placeholder="고객/계약금/일정 표시"></div></div><button class="btn" onclick="siteQuotePreview()">견적서 미리보기 팝업</button><button class="btn" onclick="photoPopup('현장사진')">현장사진 첨부/미리보기</button></div>`+form(edit?'현장 수정':'현장 신규 등록',siteFields,'sites',edit)+`<div class="card"><h3>현장 목록</h3>${table(rows,[['site_name','현장명'],['customer_name','고객명'],['status','상태','status'],['contract_amount','총공사금','money'],['rough_start','선배관 시작'],['rough_end','선배관 종료'],['install_start','기계설치 시작'],['install_end','기계설치 종료']], 'sites')}</div>`},
 quotes:async()=>{return title('견적관리')+`<div class="tabs"><button class="${state.tab.quote==='single'?'active':''}" onclick="state.tab.quote='single';loadPage()">싱글 견적 작성</button><button class="${state.tab.quote==='multi'?'active':''}" onclick="state.tab.quote='multi';loadPage()">멀티 견적 첨부</button></div>`+(state.tab.quote==='single'?singleQuoteView():multiQuoteView())},
 products:async()=>{const rows=state.data.products||[];const edit=state.editing?.table==='products'?state.editing.row:null;return title('상품DB')+`<div class="card"><h3>상품 선택 구조</h3><div class="form-grid"><div class="field"><label>품목</label><select id="pfCat" onchange="renderProductFilter()"><option value="">전체</option>${[...new Set(rows.map(p=>p.category).filter(Boolean))].map(x=>`<option>${esc(x)}</option>`).join('')}</select></div><div class="field"><label>라인업</label><select id="pfLine" onchange="renderProductFilter()"><option value="">전체</option></select></div><div class="field"><label>세부구분</label><select id="pfSub" onchange="renderProductFilter()"><option value="">전체</option></select></div></div><div id="productFiltered" class="small">총 ${rows.length}개 모델</div></div>`+form(edit?'상품 수정':'상품 신규 등록',[['brand','브랜드'],['category','품목'],['line_up','라인업'],['sub_type','세부구분'],['model','모델명'],['cooling_type','냉방구분'],['power_phase','전원'],['area','평형'],['hp','마력'],['price','공급가','number'],['install_fee','기본설치비','number']], 'products', edit)+`<div class="card"><h3>상품 목록 (${rows.length}개)</h3>${table(rows.slice(0,300),[['brand','브랜드'],['category','품목'],['line_up','라인업'],['sub_type','세부구분'],['model','모델명'],['cooling_type','냉방'],['power_phase','전원'],['area','평형'],['hp','마력'],['price','공급가','money'],['install_fee','설치비','money']], 'products')}</div>`},
 extras:async()=>{const rows=await api('/extra_fees');return title('추가비DB')+form('추가비 항목 등록',[['name','항목명'],['memo','비고']], 'extra_fees')+`<div class="card"><h3>추가비 항목</h3><p class="small">금액은 견적서에서 수기 입력</p>${table(rows,[['name','항목'],['memo','비고']], 'extra_fees')}</div>`},
 materials:async()=>{const rows=state.data.materials||[];return title('자재관리')+`<div class="grid half"><div>${form('자재 등록',[['name','자재명'],['category','분류'],['unit','단위'],['stock','현재고','number'],['manage_stock','재고관리','select',['1','0']],['memo','비고']], 'materials')}</div><div>${form('입출고 등록',[['site_name','현장명','site'],['material_name','자재명'],['move_type','구분','select',['입고','출고']],['qty','수량','number'],['memo','비고']], 'stock_moves')}</div></div><div class="card"><h3>자재DB / 재고현황</h3><div class="toolbar"><button class="btn" onclick="filterMaterial('냉매배관 직관')">직관</button><button class="btn" onclick="filterMaterial('냉매배관 세트')">배관세트</button><button class="btn" onclick="filterMaterial('PVC')">PVC</button><button class="btn" onclick="filterMaterial('행거')">행거</button><button class="btn" onclick="filterMaterial('전기')">전기/통신</button></div><div id="matTable">${table(rows,[['name','자재명'],['category','분류'],['unit','단위'],['stock','재고'],['memo','비고']], 'materials')}</div></div>`},
 tax:async()=>{const rows=await api('/tax_entries');const d=await api('/dashboard');const sales=rows.filter(r=>r.direction==='매출'), pur=rows.filter(r=>r.direction==='매입');return title('세무관리')+`<div class="grid cards">${card('총공사금',money(d.totalContract),'blue')}${card('총매출',money(d.sales),'green')}${card('총매입',money(d.purchase),'red')}${card('수익금',money(d.profit),d.profit>=0?'green':'red')}${card('미수금',money(d.receivable),'red')}${card('미지급금',money(d.payable),'orange')}</div><div class="tabs"><button class="${state.tab.tax==='sales'?'active':''}" onclick="state.tab.tax='sales';loadPage()">매출관리</button><button class="${state.tab.tax==='purchase'?'active':''}" onclick="state.tab.tax='purchase';loadPage()">매입관리</button><button class="${state.tab.tax==='proof'?'active':''}" onclick="state.tab.tax='proof';loadPage()">증빙관리</button></div>${form('세무 입력',taxFields,'tax_entries')}<div class="card"><h3>${state.tab.tax==='sales'?'매출관리':state.tab.tax==='purchase'?'매입관리':'증빙관리'}</h3>${state.tab.tax==='proof'?proofView(rows):table(state.tab.tax==='sales'?sales:pur,[['site_name','현장명'],['category','항목'],['amount','금액','money'],['paid_amount','실결제/입금','money'],['pay_status','상태','status'],['proof_type','증빙'],['paid_date','일자']], 'tax_entries')}</div>`},
 contracts:async()=>title('계약관리')+form('글로싸인 계약 생성',[['site_name','현장명','site'],['contract_date','계약일','date'],['quote_type','계약유형','select',['싱글 시스템','멀티 시스템']],['total_amount','계약금액','number'],['deposit_percent','계약금 %','number'],['middle_percent','중도금 %','number'],['balance_percent','잔금 %','number'],['deposit_date','계약금 지급일','date'],['middle_date','중도금 지급일','date'],['balance_date','잔금 지급일','date'],['status','상태','select',['초안','발송완료','서명대기','계약완료','계약파기']]], 'contracts')+`<div class="card"><h3>계약서 첨부 원칙</h3><p>싱글은 계약서 품목 표시, 멀티는 견적서 PDF + LATS 설계도 첨부. 별첨 문서는 계약서와 동일 효력.</p><button class="btn primary">계약서 생성</button><button class="btn">글로싸인 발송</button><button class="btn">서명상태 확인</button></div>`,
 as:async()=>{const rows=await api('/as_requests');return title('AS관리')+form('AS 접수/처리',[['site_name','현장명','site'],['customer_name','고객명'],['phone','연락처'],['visit_date','방문예정일','date'],['engineer','담당기사'],['status','상태','select',['접수','방문완료','미처리','부품대기','재방문예정','완료','유상청구','무상AS']],['symptom','증상','select',['냉방불량','난방불량','누수','소음','통신불량','에러코드','기타']],['error_code','에러코드'],['cause','원인','textarea'],['action','조치내용','textarea'],['sales_amount','AS매출','number'],['cost_amount','AS지출','number']], 'as_requests')+`<div class="card"><h3>현장사진</h3><button class="btn" onclick="photoPopup('AS 현장사진')">현장사진 업로드/미리보기</button></div><div class="card"><h3>AS 목록</h3>${table(rows,[['site_name','현장명'],['customer_name','고객명'],['status','상태','status'],['symptom','증상'],['visit_date','방문일'],['sales_amount','매출','money'],['cost_amount','지출','money']], 'as_requests')}</div>`},
 customers:async()=>{const rows=state.data.customers||[];return title('업체/고객관리')+form('업체/고객 등록',[['type','구분','select',['개인고객','업체고객','협력업체','거래처']],['name','고객명/업체명'],['ceo','대표자'],['manager','담당자'],['phone','연락처'],['manager_phone','담당자 연락처'],['email','이메일'],['address','주소'],['biz_no','사업자등록번호'],['business','업태'],['biz_type','종목'],['trade_type','거래구분'],['payment_method','결제방식','select',['세금계산서','카드','현금영수증','현금','계좌이체']],['payment_condition','결제조건','select',['당월말','익월말','현장 완료 후','협의','직접입력']]], 'customers')+`<div class="card"><h3>사후관리</h3><p>설치완료 후 6개월 사용상태/이상유무 카톡 알림</p><button class="btn primary" onclick="aftercareKakao()">카톡 알림 발송</button><button class="btn">AS 등록</button><button class="btn">다음 알림 예약</button></div><div class="card"><h3>고객 목록</h3>${table(rows,[['type','구분'],['name','고객/업체명'],['phone','연락처'],['trade_type','거래구분'],['payment_condition','결제조건']], 'customers')}</div>`},
 employees:async()=>{const rows=await api('/employees');return title('직원관리 / 권한설정')+form('직원 등록',[['name','이름'],['phone','연락처'],['role','직급'],['type','구분','select',['관리자','회계','현장기사','보조공','외주기사']],['hire_date','입사일','date'],['leave_date','퇴사일','date'],['daily_wage','기본일당','number'],['account','계좌정보'],['permissions','권한'],['memo','비고','textarea']], 'employees')+`<div class="card"><h3>권한 기본값</h3><p>관리자 전체 / 회계 세무·증빙 / 현장기사 일정·현장·사진·AS / 보조공 일정·사진 / 외주기사 배정현장만</p></div><div class="card"><h3>직원 목록</h3>${table(rows,[['name','이름'],['phone','연락처'],['role','직급'],['type','구분'],['daily_wage','일당','money'],['permissions','권한']], 'employees')}</div>`},
 approvals:async()=>{const rows=await api('/approvals');return title('내부결제')+form('내부결제 요청',[['site_name','현장명','site'],['request_date','요청일','date'],['requester','요청자'],['category','결제항목','select',['기계대','자재비','인건비','장비비','AS 부품비','기타비']],['amount','금액','number'],['vendor','거래처'],['due_date','결제기한','date'],['status','상태','select',['작성중','검토중','대표승인대기','승인완료','반려','결제완료']],['reason','사유','textarea']], 'approvals')+`<div class="card"><h3>결재라인</h3><p>1차 검토: 안수원 → 최종 승인: 문지원</p>${table(rows,[['site_name','현장명'],['category','항목'],['amount','금액','money'],['vendor','거래처'],['status','상태','status'],['due_date','기한']], 'approvals')}</div>`},
 network:async()=>{const rows=await api('/billings');return title('업체 네트워크 / 청구시스템')+form('업체 간 청구서',[['site_name','현장명','site'],['partner','상대업체'],['work','작업내용'],['amount','청구금액','number'],['vat','VAT','number'],['status','상태','select',['작성중','발송완료','승인대기','승인완료','입금완료','반려']],['memo','메모','textarea']], 'billings')+`<div class="card"><h3>업체 간 매출/매입 연동</h3><p>청구 승인 시 발행 업체는 매출, 수신 업체는 매입으로 관리하는 구조.</p>${table(rows,[['site_name','현장명'],['partner','업체'],['work','작업'],['amount','청구금액','money'],['status','상태','status']], 'billings')}</div>`},
 settings:async()=>{const c=await api('/settings/company');return title('설정 / 회사정보')+`<div class="card"><h3>회사정보</h3><div class="form-grid"><div class="field"><label>상호</label><input value="${esc(c.name)}"></div><div class="field"><label>대표자</label><input value="${esc(c.ceo)}"></div><div class="field"><label>사업자번호</label><input value="${esc(c.biz_no)}"></div><div class="field"><label>주소</label><input value="${esc(c.address)}"></div><div class="field"><label>연락처</label><input value="${esc(c.phone)}"></div><div class="field"><label>FAX</label><input value="${esc(c.fax)}"></div><div class="field"><label>견적담당자</label><input value="${esc(c.manager)}"></div><div class="field"><label>담당자 연락처</label><input value="${esc(c.manager_phone)}"></div><div class="field"><label>계좌</label><input value="${esc(c.bank)}"></div></div></div><div class="card"><h3>기본설정</h3><p>VAT 포함/별도, 견적서 번호, 계약서 번호, 기본 결제비율, 카톡 문구, 사후관리 6개월 알림</p></div>`},
 security:async()=>{const rows=await api('/security_logs');return title('보안센터')+`<div class="card"><h3>보안 기능</h3><p>로그인 기록, 직원 접속 기록, 권한 변경 이력, 삭제 이력, 백업 다운로드, 관리자 잠금 방지</p></div><div class="card">${table(rows,[['user','사용자'],['action','작업'],['ip','IP'],['created_at','일시']])}</div>`},
 mhome:async()=>title('모바일 홈')+`<div class="card"><h3>오늘 일정</h3><p>선배관 / 기계설치 / AS방문</p></div><div class="card"><button class="btn primary" onclick="photoPopup('현장사진')">사진 업로드</button><button class="btn">AS 등록</button></div>`,
 mschedule:async()=>pages.dashboard(), msites:async()=>pages.sites(), mas:async()=>pages.as(), mprofile:async()=>title('내정보')+`<div class="card"><button class="btn primary">출근</button><button class="btn">퇴근</button><p>연차 / 반차 / 월차 관리</p></div>`
};
function singleQuoteView(){return `<div class="grid two"><div class="card"><h3>싱글 견적 작성</h3><div class="form-grid"><div class="field"><label>모델명</label><select id="qProduct" onchange="quoteCalc()">${productOptions()}</select></div><div class="field"><label>수량</label><input id="qQty" type="number" value="1" onchange="quoteCalc()"></div><div class="field"><label>기본 배관(m)</label><input id="qBasePipe" type="number" value="15" onchange="quoteCalc()"></div><div class="field"><label>추가 배관(m)</label><input id="qExtraPipe" type="number" value="0" onchange="quoteCalc()"></div><div class="field"><label>기본 PVC 드레인(m)</label><input id="qBaseDrain" type="number" value="16" onchange="quoteCalc()"></div><div class="field"><label>PVC 드레인 추가(m)</label><input id="qExtraDrain" type="number" value="0" onchange="quoteCalc()"></div></div><button class="btn primary" onclick="quoteCalc()">자동 산출</button><button class="btn">PDF 생성</button><button class="btn">프린터</button><button class="btn">현장 생성</button></div><div class="card"><h3>자동 산출 결과</h3><div id="quoteResult" class="small">모델을 선택하세요.</div></div></div><div class="card"><h3>추가비</h3><p>배관추가, 앵글, 바닥앵글, 2단앵글, 바람막이, 스카이, 크레인, 지게차 등 금액 수기 입력</p></div>`}
function multiQuoteView(){return `<div class="card"><h3>멀티 견적 첨부</h3><p>멀티는 LATS 기반 파일/견적서 첨부 방식. 계약 시 견적서와 LATS 설계도를 별첨으로 연결.</p><div class="upload-zone">LATS Excel / PDF / 멀티견적서 업로드</div><button class="btn primary">파일 첨부</button><button class="btn">현장 연결</button></div>`}
async function quoteCalc(){const id=gid('qProduct')?.value;if(!id)return;const body={product_id:id,qty:gid('qQty').value,base_pipe:gid('qBasePipe').value,extra_pipe:gid('qExtraPipe').value,base_drain:gid('qBaseDrain').value,extra_drain:gid('qExtraDrain').value};const r=await api('/quote/single/calc',{method:'POST',body:JSON.stringify(body)});gid('quoteResult').innerHTML=`<div class="kpi-row"><div class="kpi">예상금액<b>${money(r.amount)}</b></div><div class="kpi">배관규격<b>${r.pipeSet}</b></div></div>${table(r.materials,[['item','자재'],['qty','수량'],['unit','단위']])}`}
function proofView(rows){return `<p>세금계산서 / 카드사용내역 / 현금영수증 / 거래명세표 / 통장내역 관리</p>${table(rows,[['site_name','현장명'],['direction','구분'],['proof_type','증빙'],['amount','금액','money'],['pay_status','상태','status']])}`}
function showSite(id){const r=(state.data.sites||[]).find(x=>x.id===id);if(!r)return;gid('siteInfo').value=`${r.customer_name||''} / ${money(r.contract_amount)} / 선배관 ${r.rough_start||''}~${r.rough_end||''} / 기계 ${r.install_start||''}~${r.install_end||''}`}
function siteQuotePreview(){modal('<h2>견적서 미리보기</h2><p>현장관리에서 연결된 견적서 PDF를 팝업으로 확인합니다.</p><div class="upload-zone">견적서 첨부파일 미리보기 영역</div>')}
function photoPopup(title){modal(`<h2>${title}</h2><div class="upload-zone">사진 첨부하기 · 최대 10장</div><div class="photo-grid">${Array.from({length:10},(_,i)=>`<div class="photo">미리보기 ${i+1}</div>`).join('')}</div><br><button class="btn">다운로드</button><button class="btn">카톡전송</button>`) }
function schedulePopup(day){modal(`<h2>${day}일 일정 등록</h2><div class="form-grid"><div class="field"><label>일정구분</label><select><option>견적</option><option>선배관</option><option>기계설치</option><option>AS</option></select></div><div class="field"><label>현장</label><select>${siteOptions()}</select></div><div class="field"><label>사진</label><input type="file"></div></div><button class="btn primary">저장</button>`) }
function renderProductFilter(){const rows=state.data.products||[];const c=gid('pfCat')?.value||'';const line=gid('pfLine');const sub=gid('pfSub');if(line){const lines=[...new Set(rows.filter(p=>!c||p.category===c).map(p=>p.line_up).filter(Boolean))];line.innerHTML='<option value="">전체</option>'+lines.map(x=>`<option>${esc(x)}</option>`).join('')}const l=line?.value||'';if(sub){const subs=[...new Set(rows.filter(p=>(!c||p.category===c)&&(!l||p.line_up===l)).map(p=>p.sub_type).filter(Boolean))];sub.innerHTML='<option value="">전체</option>'+subs.map(x=>`<option>${esc(x)}</option>`).join('')}const s=sub?.value||'';const cnt=rows.filter(p=>(!c||p.category===c)&&(!l||p.line_up===l)&&(!s||p.sub_type===s)).length;const box=gid('productFiltered');if(box)box.textContent=`검색 결과 ${cnt}개 모델`;}
function filterMaterial(cat){const rows=(state.data.materials||[]).filter(m=>String(m.category||m.name).includes(cat)||String(m.name).includes(cat));gid('matTable').innerHTML=table(rows,[['name','자재명'],['category','분류'],['unit','단위'],['stock','재고'],['memo','비고']], 'materials')}
function aftercareKakao(){alert('카톡 알림 문구: 설치 후 사용 상태 확인차 연락드립니다. 냉방/난방/소음/누수/리모컨 이상이 있으시면 말씀해주세요.');}
mount();
